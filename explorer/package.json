{
  "name": "explorer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:flights": "node server/index.mjs",
    "dev:flights:legacy": "node server/flights-proxy.mjs",
    "fetch:weather:stage1": "node source-fetchers/weather/stage1_clean_slate_fetch.mjs",
    "fetch:weather:stage1:clean": "node source-fetchers/weather/stage1_clean_slate_fetch.mjs --clean-only",
    "fetch:weather:stage1:resume": "node source-fetchers/weather/stage1_clean_slate_fetch.mjs --fetch-only",
    "fetch:weather:tier": "node source-fetchers/weather/tiered_weather_fetch.mjs",
    "fetch:weather:tier1": "node source-fetchers/weather/tiered_weather_fetch.mjs --tier 1",
    "fetch:weather:tier2": "node source-fetchers/weather/tiered_weather_fetch.mjs --tier 2",
    "fetch:weather:tier3": "node source-fetchers/weather/tiered_weather_fetch.mjs --tier 3",
    "fetch:weather:tier4": "node source-fetchers/weather/tiered_weather_fetch.mjs --tier 4",
    "fetch:weather:tier5": "node source-fetchers/weather/tiered_weather_fetch.mjs --tier 5",
    "normalize:weather:stage2": "node normalization/weather/pipelines/stage2_jsonl_pipeline.mjs",
    "insert:weather:stage3": "node normalization/weather/pipelines/stage3_postgres_insert_pipeline.mjs",
    "db:weather:views": "node normalization/weather/pipelines/apply_weather_intelligence_views.mjs",
    "report:weather": "node scripts/weather_stage_report.mjs",
    "weather:refresh": "npm run normalize:weather:stage2 && npm run insert:weather:stage3 && npm run report:weather",
    "normalize:weather:mvp": "node normalization/weather/pipelines/mvp_open_meteo_pipeline.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "cesium": "^1.121.2",
    "csv-parse": "^6.2.1",
    "fast-xml-parser": "^5.7.2",
    "h3-js": "^4.4.0",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resium": "^1.19.0-beta.1",
    "satellite.js": "^7.0.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-cesium": "^1.2.22"
  }
}
