# Copy this file to `.env` in the same directory and fill in your token.
# `.env` is gitignored and must NEVER be committed.
#
# Get a token at: https://ion.cesium.com/tokens
#
# Security checklist (do this in the Ion dashboard):
#   1. Domain-restrict the token to `localhost`, `127.0.0.1`, and your deploy domain.
#   2. Scope the token to only the assets you use:
#        - Bing Maps Aerial with Labels  (asset id 3)
#        - Cesium World Terrain           (asset id 1)
#        - Cesium OSM Buildings           (asset id 96188)  [added in Phase 3]
#   3. Set a usage alert in the Ion dashboard so you notice quota spikes.

VITE_CESIUM_ION_TOKEN=

# Optional flight-feed settings.
# OpenSky now recommends OAuth2 client credentials for authenticated access.
# If omitted, the proxy will attempt anonymous access and fall back to mock
# data when OpenSky is unavailable.
FLIGHT_PROXY_PORT=8788
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Optional local aircraft metadata CSV keyed by ICAO24 (hex) with columns such
# as icao24, typecode, model, manufacturername, registration, operator.
# Drop a file at server/data/aircraft-metadata.csv or point this variable at it.
AIRCRAFT_METADATA_CSV_PATH=

# Space-Track credentials are required for the satellite TLE catalog.
# The backend logs in once, caches active GP TLEs, then propagates locally.
SPACETRACK_EMAIL=
SPACETRACK_PASSWORD=

# Optional: enables live maritime AIS traffic for the Subsea Infrastructure layer.
AISSTREAM_API_KEY=

# Optional: enables the Global Fishing Watch maritime trade layer
# (cargo + bunker/tanker vessels) through the backend `/api/maritime` endpoint.
GFW_API_KEY=

# Optional: enables OpenWeatherMap-backed global climate telemetry.
VITE_OWM_API_KEY=
OWM_API_KEY=
OPENWEATHER_API_KEY=

# Optional: active fire/hazard, camera, economy, and conflict/event expansion sources.
NASA_FIRMS_MAP_KEY=
WINDY_WEBCAMS_API_KEY=
EARTHCAM_API_KEY=
EIA_API_KEY=
UN_COMTRADE_API_KEY=
ACLED_API_KEY=
OPENCHARGEMAP_API_KEY=

# Optional: user-owned expansion feed.
CUSTOM_API_URL=
CUSTOM_API_KEY=
GODS_EXPANSION_API_KEY=

# Optional: lightweight rail/metro tactical overlays.
# Provider can be `maptiler` (default) or `mapbox`.
VITE_TRANSIT_TILE_PROVIDER=maptiler

# MapTiler tactical rail overlays.
VITE_MAPTILER_API_KEY=
VITE_MAPTILER_METRO_STYLE_ID=
VITE_MAPTILER_RAILWAY_STYLE_ID=

# Mapbox tactical rail overlays.
VITE_MAPBOX_ACCESS_TOKEN=
VITE_MAPBOX_USERNAME=
VITE_MAPBOX_METRO_STYLE_ID=
VITE_MAPBOX_RAILWAY_STYLE_ID=
